# =============================================================================
# Mema — Environment Variables
# =============================================================================
# Copy to .env and fill in actual values.
# LLM model variables are read on each call — swappable without restart.

# --- Timezone (REQUIRED in production, warned in dev) ---
# rrule.js TZID+DST breaks when process TZ != UTC (see docs/decisions/006)
# Production: startup fails if TZ != UTC
# Dev: logs a warning but continues
# Set in Dockerfile: ENV TZ=UTC
# Set in dev scripts: TZ=UTC bun run dev
TZ=UTC

# --- Application (optional, defaults shown) ---
NODE_ENV=development              # "development" | "production" | "test"
PORT=3000                         # integer, positive
LOG_LEVEL=info                    # "fatal"|"error"|"warn"|"info"|"debug"|"trace"

# --- Database (PostgreSQL + pgvector) --- (REQUIRED)
# Use "localhost" for local development, "db" for Docker Compose
DATABASE_URL=postgresql://mema:password@localhost:5432/mema

# Docker Compose / scripts only (NOT validated by Zod schema)
POSTGRES_DB=mema
POSTGRES_USER=mema
POSTGRES_PASSWORD=password

# External port for PostgreSQL container (change if 5432 is already in use)
# Docker Compose / scripts only (NOT validated by Zod schema)
DB_PORT=5432

# --- Telegram --- (REQUIRED)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Optional — long polling by default, webhook post-MVP
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook

# --- LLM Providers --- (REQUIRED)
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- LLM Models (REQUIRED, swappable without restart) ---
LLM_COMPACT_MODEL=gpt-5-nano
LLM_POWERFUL_MODEL_A=claude-opus-4-6
LLM_POWERFUL_MODEL_B=gpt-5.2
LLM_VALIDATOR_MODEL=gpt-5-nano
LLM_EMBEDDING_MODEL=text-embedding-3-small

# --- Administration --- (REQUIRED)
ADMIN_USER_ID=your-telegram-user-id

# --- Sentry (Error Monitoring) --- (optional)
SENTRY_DSN=your-sentry-dsn

# --- Rate Limiting (optional, defaults shown) ---
RATE_LIMIT_PER_HOUR=100           # integer, non-negative

# --- Token Quota (optional, defaults shown) ---
# Monthly token limit per user (value TBD after launch; 0 = unlimited)
TOKEN_QUOTA_MONTHLY=0             # integer, non-negative

# --- Backup (Backblaze B2, S3-compatible) ---
# Docker Compose / scripts only (NOT validated by Zod schema)
B2_APPLICATION_KEY_ID=your-b2-key-id
B2_APPLICATION_KEY=your-b2-application-key
B2_BUCKET_NAME=mema-backups
B2_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com
